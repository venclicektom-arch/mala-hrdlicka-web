---
// src/layouts/Layout.astro
import '../styles/global.css';
import { Image } from 'astro:assets';
import logo from '../assets/images/homepage/logo-hrdlicka.png';

import '@fontsource/outfit/300.css';
import '@fontsource/outfit/400.css';
import '@fontsource/outfit/500.css';
import '@fontsource/outfit/600.css';
import '@fontsource/outfit/700.css';

// Definujeme, jaké informace může každá stránka poslat do layoutu
const { title = 'Malá Hrdlička | Ubytování Slapy', description = 'Rodinný areál Malá Hrdlička na Slapech. Nabízíme apartmány a chatky jen 5 minut od vody. Ideální pro rodiny s dětmi.', ogImage = '/img/og-image.jpg' } = Astro.props;

// Automatické sestavení kanonické URL podle aktuální stránky
const canonicalURL = new URL(Astro.url.pathname, 'https://slapy-hrdlicka.cz');
---

<!doctype html>
<html lang="cs" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Malá Hrdlička" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site ?? Astro.url)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Areál Malá Hrdlička u Slapské přehrady" />
    <meta property="og:site_name" content="Malá Hrdlička" />
    <meta property="og:locale" content="cs_CZ" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site ?? Astro.url)} />
    <meta name="twitter:image:alt" content="Areál Malá Hrdlička u Slapské přehrady" />

    <link rel="icon" type="image/png" href="/public/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/public/favicon.svg" />
    <link rel="shortcut icon" href="/public/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/public/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Malá Hrdlička" />
    <link rel="manifest" href="/public/site.webmanifest" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'LodgingBusiness',
        name: 'Areál Malá Hrdlička',
        description: 'Rodinný areál s apartmány a chatkami u Slapské přehrady. Otevřeno červen–říjen.',
        url: 'https://slapy-hrdlicka.cz',
        telephone: '+420777121663',
        email: 'pajula@volny.cz',
        image: 'https://slapy-hrdlicka.cz/img/og-image.jpg',
        priceRange: '$$',
        address: {
          '@type': 'PostalAddress',
          streetAddress: 'Osada Hrdlička',
          addressLocality: 'Čím',
          postalCode: '262 03',
          addressRegion: 'Středočeský kraj',
          addressCountry: 'CZ',
        },
        geo: {
          '@type': 'GeoCoordinates',
          latitude: 49.784,
          longitude: 14.4028,
        },
        openingHoursSpecification: {
          '@type': 'OpeningHoursSpecification',
          validFrom: '2026-06-01',
          validThrough: '2026-10-31',
        },
        petsAllowed: true,
        numberOfRooms: '12',
      })}
    />
  </head>
  <body class="bg-[#F4F1EA] text-[#3A4535] font-['Outfit',sans-serif] flex flex-col min-h-screen">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:bg-[#C5A059] focus:text-white focus:px-4 focus:py-2 focus:rounded-sm focus:font-bold"> Přejít na hlavní obsah </a>
    <header class="bg-[#4F7942]/95 backdrop-blur-md sticky top-0 z-50 shadow-md border-b border-white/10">
      <div class="max-w-7xl mx-auto px-4 lg:px-6 h-16 md:h-20 flex justify-between items-center relative gap-3">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 md:gap-3 group z-20 shrink-0 min-w-0">
          <Image src={logo} alt="Logo areálu Malá Hrdlička" width={47} height={64} format="avif" quality={80} loading="eager" fetchpriority="high" decoding="sync" class="h-12 md:h-16 w-auto object-contain transition-all duration-300 group-hover:scale-110" />
          <div class="flex flex-col min-w-0">
            <span class="text-base md:text-xl font-bold tracking-tight text-white group-hover:text-[#C5A059] transition-colors truncate"> MALÁ HRDLIČKA </span>
            <span class="hidden sm:block text-[8px] md:text-[9px] uppercase tracking-[0.3em] font-bold text-[#C5A059] truncate"> Apartmány & Chatky </span>
          </div>
        </a>

        <!-- DESKTOP NAV (lg+, tj. od 1024px) -->
        <nav aria-label="Hlavní navigace" class="hidden lg:flex items-center gap-6 xl:gap-10">
          <a href="/" class="text-[12px] uppercase tracking-widest font-semibold text-white hover:text-[#C5A059] transition">Úvod</a>
          <a href="/o-nas" class="text-[12px] uppercase tracking-widest font-semibold text-white hover:text-[#C5A059] transition">O areálu</a>

          <!-- Dropdown Ubytování -->
          <div class="relative py-8" id="dropdown-wrapper">
            <button id="dropdown-btn" aria-expanded="false" aria-controls="dropdown-menu" aria-haspopup="true" class="flex items-center gap-1.5 text-[12px] uppercase tracking-widest font-semibold text-white hover:text-[#C5A059] transition focus:outline-none focus-visible:text-[#C5A059]">
              Ubytování
              <svg id="dropdown-arrow" class="w-3.5 h-3.5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>

            <div id="dropdown-menu" role="menu" class="absolute top-full left-0 w-48 bg-[#4F7942] border border-white/10 shadow-xl opacity-0 invisible transition-all duration-300 translate-y-2 rounded-sm z-50">
              <div class="py-2 flex flex-col">
                <a href="/ubytovani#apartmany" role="menuitem" class="px-5 py-3 text-[11px] uppercase tracking-widest font-bold text-white hover:text-[#C5A059] hover:bg-white/10 transition">Apartmány</a>
                <a href="/ubytovani#chatky" role="menuitem" class="px-5 py-3 text-[11px] uppercase tracking-widest font-bold text-white hover:text-[#C5A059] hover:bg-white/10 transition">Chatky</a>
              </div>
            </div>
          </div>

          <a href="/aktivity" class="text-[12px] uppercase tracking-widest font-semibold text-white hover:text-[#C5A059] transition">Aktivity</a>
          <a href="/galerie" class="text-[12px] uppercase tracking-widest font-semibold text-white hover:text-[#C5A059] transition">Galerie</a>
          <a href="/cenik" class="text-[12px] uppercase tracking-widest font-semibold text-white hover:text-[#C5A059] transition">Ceník</a>
          <a href="/kontakt" class="text-[12px] uppercase tracking-widest font-semibold text-white hover:text-[#C5A059] transition">Kontakt</a>
        </nav>

        <!-- PRAVÁ ČÁST: Tlačítko Rezervovat (tablet+) + Hamburger (do lg) -->
        <div class="flex items-center gap-3 z-20 shrink-0">
          <!-- Rezervovat — viditelné od tabletu výš (md+) -->
          <a href="/kontakt" class="hidden md:inline-block lg:hidden bg-[#C5A059] text-white px-4 py-2 rounded-sm text-[10px] uppercase tracking-wider font-bold hover:bg-white hover:text-[#4F7942] transition-all duration-300 shadow-md whitespace-nowrap"> Rezervovat </a>
          <a href="/kontakt" class="hidden lg:inline-block bg-[#C5A059] text-white px-6 xl:px-8 py-3 rounded-sm text-[11px] uppercase tracking-[0.2em] font-bold hover:bg-white hover:text-[#4F7942] transition-all duration-300 shadow-md whitespace-nowrap"> Rezervovat </a>

          <!-- Hamburger — mobil + tablet (< lg, tj. do 1023px včetně) -->
          <button id="mobile-menu-btn" aria-label="Otevřít navigaci" aria-expanded="false" aria-controls="mobile-menu" class="lg:hidden text-white hover:text-[#C5A059] p-2 focus:outline-none transition-colors -mr-2">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 8h16M4 16h16"></path>
              <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
      </div>

      <!-- MOBILE / TABLET MENU — vyjede pod hlavičkou na šířkách < 1024px -->
      <div id="mobile-menu" aria-hidden="true" class="lg:hidden overflow-hidden transition-[max-height] duration-300 ease-in-out bg-[#4F7942] border-t border-white/10 shadow-2xl z-40" style="max-height: 0px;">
        <nav aria-label="Mobilní navigace" class="flex flex-col px-6 py-2 divide-y divide-white/10 max-w-3xl mx-auto">
          <a href="/" class="py-4 text-[13px] uppercase tracking-widest font-bold text-white hover:text-[#C5A059]">Úvod</a>
          <a href="/o-nas" class="py-4 text-[13px] uppercase tracking-widest font-bold text-white hover:text-[#C5A059]">O areálu</a>
          <div class="py-4 flex flex-col gap-3">
            <a href="/ubytovani" class="text-[13px] uppercase tracking-widest font-bold text-white hover:text-[#C5A059]">Ubytování</a>
            <div class="flex flex-col gap-3 pl-4 border-l border-white/20 ml-2 mt-1">
              <a href="/ubytovani#apartmany" class="text-[11px] uppercase tracking-widest font-bold text-white/80 hover:text-[#C5A059]">Apartmány</a>
              <a href="/ubytovani#chatky" class="text-[11px] uppercase tracking-widest font-bold text-white/80 hover:text-[#C5A059]">Chatky</a>
            </div>
          </div>
          <a href="/aktivity" class="py-4 text-[13px] uppercase tracking-widest font-bold text-white hover:text-[#C5A059]">Aktivity</a>
          <a href="/galerie" class="py-4 text-[13px] uppercase tracking-widest font-bold text-white hover:text-[#C5A059]">Galerie</a>
          <a href="/cenik" class="py-4 text-[13px] uppercase tracking-widest font-bold text-white hover:text-[#C5A059]">Ceník</a>
          <a href="/kontakt" class="py-4 text-[13px] uppercase tracking-widest font-bold text-white hover:text-[#C5A059]">Kontakt</a>
          <div class="py-5 md:hidden">
            <a href="/kontakt" class="block text-center bg-[#C5A059] text-white px-8 py-3.5 rounded-sm text-[11px] uppercase tracking-[0.2em] font-bold hover:bg-white hover:text-[#4F7942] transition-all duration-300 shadow-md"> Rezervovat </a>
          </div>
        </nav>
      </div>
    </header>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const menuIcon = document.getElementById('menu-icon');
      const closeIcon = document.getElementById('close-icon');

      if (btn && menu && menuIcon && closeIcon) {
        const closeMenu = () => {
          menu.style.maxHeight = '0px';
          menu.setAttribute('aria-hidden', 'true');
          btn.setAttribute('aria-expanded', 'false');
          btn.setAttribute('aria-label', 'Otevřít navigaci');
          menuIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');
        };

        const openMenu = () => {
          menu.style.maxHeight = menu.scrollHeight + 'px';
          menu.setAttribute('aria-hidden', 'false');
          btn.setAttribute('aria-expanded', 'true');
          btn.setAttribute('aria-label', 'Zavřít navigaci');
          menuIcon.classList.add('hidden');
          closeIcon.classList.remove('hidden');
        };

        btn.addEventListener('click', () => {
          const isOpen = menu.style.maxHeight !== '0px' && menu.style.maxHeight !== '';
          isOpen ? closeMenu() : openMenu();
        });

        // Při resize na desktop (>=1024px) menu zavřeme
        window.addEventListener('resize', () => {
          if (window.innerWidth >= 1024) {
            closeMenu();
          }
        });

        // Při kliknutí na odkaz menu zavřeme (lepší UX na tabletech)
        menu.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', closeMenu);
        });
      }

      // Dropdown Ubytování (jen desktop)
      const dropBtn = document.getElementById('dropdown-btn');
      const dropMenu = document.getElementById('dropdown-menu');
      const dropArrow = document.getElementById('dropdown-arrow');
      const dropWrapper = document.getElementById('dropdown-wrapper');

      if (dropBtn && dropMenu && dropWrapper) {
        const openDrop = () => {
          dropMenu.classList.remove('opacity-0', 'invisible', 'translate-y-2');
          dropMenu.classList.add('opacity-100', 'visible', 'translate-y-0');
          dropArrow?.classList.add('rotate-180');
          dropBtn.setAttribute('aria-expanded', 'true');
        };

        const closeDrop = () => {
          dropMenu.classList.add('opacity-0', 'invisible', 'translate-y-2');
          dropMenu.classList.remove('opacity-100', 'visible', 'translate-y-0');
          dropArrow?.classList.remove('rotate-180');
          dropBtn.setAttribute('aria-expanded', 'false');
        };

        dropWrapper.addEventListener('mouseenter', openDrop);
        dropWrapper.addEventListener('mouseleave', closeDrop);

        dropBtn.addEventListener('click', () => {
          dropBtn.getAttribute('aria-expanded') === 'true' ? closeDrop() : openDrop();
        });

        document.addEventListener('click', (e) => {
          if (!dropWrapper.contains(e.target as Node)) closeDrop();
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') closeDrop();
        });
      }
    </script>

    <main id="main-content" class="flex-grow">
      <slot />
    </main>

    <footer class="bg-[#4F7942] text-[#EFEBE0]/80 pt-20 pb-10 px-6 mt-auto border-t border-[#C5A059]/20">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-16">
        <!-- Sloupec 1: Logo + popis + social -->
        <div>
          <span class="text-2xl font-bold tracking-tight text-[#C5A059] mb-4 block drop-shadow-sm">Malá Hrdlička</span>
          <p class="text-sm leading-relaxed font-light mb-8 text-[#EFEBE0]/90">Zastavte se a nadechněte. Útulné ubytování v objetí přírody, jen pár kroků od břehu Slapské přehrady. Vaše letní pohoda.</p>
          <div class="flex items-center gap-4">
            <!-- Nahraď href="#" skutečným odkazem na Facebook -->
            <a href="#" aria-label="Facebook" class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center text-white hover:border-[#C5A059] hover:text-[#C5A059] hover:bg-white/10 transition-all shadow-sm">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"></path></svg>
            </a>
            <!-- Nahraď href="#" skutečným odkazem na Instagram -->
            <a href="#" aria-label="Instagram" class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center text-white hover:border-[#C5A059] hover:text-[#C5A059] hover:bg-white/10 transition-all shadow-sm">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
                ><path
                  d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"
                ></path></svg
              >
            </a>
          </div>
        </div>

        <!-- Sloupec 2: Rychlé odkazy — opravena třída group -->
        <div>
          <h4 class="text-[#C5A059] text-[10px] uppercase tracking-[0.2em] font-bold mb-6 drop-shadow-sm">Rychlé odkazy</h4>
          <ul class="space-y-3 text-[13px] font-medium">
            {
              [
                { href: '/', label: 'Úvod' },
                { href: '/o-nas', label: 'O areálu' },
                { href: '/ubytovani', label: 'Naše ubytování' },
                { href: '/aktivity', label: 'Aktivity a okolí' },
                { href: '/galerie', label: 'Fotogalerie' },
                { href: '/cenik', label: 'Ceník a služby' },
                { href: '/kontakt', label: 'Kontakt' },
              ].map((link) => (
                <li>
                  <a href={link.href} class="group text-white hover:text-[#C5A059] transition flex items-center gap-2">
                    <span class="w-1 h-1 rounded-full bg-[#C5A059] opacity-0 group-hover:opacity-100 transition-opacity shrink-0" />
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Sloupec 3: Kontakt -->
        <div>
          <h4 class="text-[#C5A059] text-[10px] uppercase tracking-[0.2em] font-bold mb-6 drop-shadow-sm">Kontakt</h4>
          <ul class="space-y-4 text-[13px]">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#C5A059] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              <div class="flex flex-col">
                <span class="text-white font-medium">Osada Hrdlička, Čím</span>
                <span class="text-[#EFEBE0]/80">Slapská přehrada</span>
              </div>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-[#C5A059] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              <a href="tel:+420777121663" class="text-white text-lg font-semibold hover:text-[#C5A059] transition">+420 777 121 663</a>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-[#C5A059] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              <a href="mailto:pajula@volny.cz" class="text-white hover:text-[#C5A059] transition">pajula@volny.cz</a>
            </li>
          </ul>
        </div>

        <!-- Sloupec 4: Check-in / Check-out -->
        <div>
          <h4 class="text-[#C5A059] text-[10px] uppercase tracking-[0.2em] font-bold mb-6 drop-shadow-sm">Informace k pobytu</h4>
          <div class="space-y-4 text-[13px]">
            <div class="bg-white/10 p-4 border border-white/20 shadow-sm">
              <p class="text-[#C5A059] text-[10px] uppercase tracking-widest font-bold mb-1">Check-in</p>
              <p class="text-white font-medium">od 14:00 hodin</p>
            </div>
            <div class="bg-white/10 p-4 border border-white/20 shadow-sm">
              <p class="text-[#C5A059] text-[10px] uppercase tracking-widest font-bold mb-1">Check-out</p>
              <p class="text-white font-medium">do 10:00 hodin</p>
            </div>
