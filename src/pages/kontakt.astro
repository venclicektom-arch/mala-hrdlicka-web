---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kontakt a rezervace | Malá Hrdlička" description="Máte dotaz nebo si chcete zarezervovat pobyt v rekreačním areálu Malá Hrdlička? Kontaktujte nás e-mailem, telefonicky nebo přes náš nezávazný rezervační formulář.">
  <main class="bg-[#F8F7F2] min-h-screen">
    <section class="pt-16 pb-16 md:pt-24 md:pb-24 bg-[#EFEBE0] relative overflow-hidden">
      <div class="absolute inset-0 opacity-[0.03]">
        <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(#1B4332_1px,transparent_1px)] [background-size:20px_20px]"></div>
      </div>

      <div class="max-w-7xl mx-auto px-6 relative z-10 text-center">
        <span class="inline-block mt-2 px-3 py-1 rounded-sm bg-[#C5A059]/10 text-[#C5A059] text-[11px] font-bold tracking-[0.3em] uppercase mb-4"> Jsme tu pro Vás </span>

        <h1 class="text-4xl md:text-6xl font-black text-[#1B4332] uppercase tracking-tight mb-6">
          Kontakt & <span class="text-[#C5A059]">Rezervace</span>
        </h1>

        <p class="text-[#5C6656] font-light max-w-2xl mx-auto text-lg leading-relaxed">Zavolejte nám, napište e-mail, nebo rovnou vyplňte předběžnou rezervaci. Rádi zodpovíme všechny Vaše dotazy a pomůžeme naplánovat Vaši dovolenou.</p>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-white relative">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-start">
          <div class="lg:col-span-5 flex flex-col gap-8 lg:sticky lg:top-32">
            <div>
              <h2 class="text-3xl font-bold text-[#1B4332] uppercase mb-4">Spojte se s námi</h2>
              <p class="text-[#5C6656] font-light mb-8">Máte raději osobní domluvu? Zavolejte nám, nebo napište e-mail. Jsme tu pro Vás a rádi s čímkoliv poradíme.</p>
            </div>

            <a href="tel:+420777121663" class="flex items-start gap-6 p-8 bg-[#F8F7F2] rounded-sm border border-[#1B4332]/10 hover:border-[#C5A059] transition-colors group">
              <div class="w-14 h-14 bg-white rounded-full flex items-center justify-center text-[#C5A059] shadow-sm shrink-0 group-hover:scale-110 transition-transform">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              </div>
              <div>
                <div class="text-[#5C6656] text-xs font-bold uppercase tracking-widest mb-1">Rezervace pobytů</div>
                <div class="text-2xl font-black text-[#1B4332]">777 121 663</div>
              </div>
            </a>

            <a href="mailto:pajula@volny.cz" class="flex items-start gap-6 p-8 bg-[#F8F7F2] rounded-sm border border-[#1B4332]/10 hover:border-[#C5A059] transition-colors group">
              <div class="w-14 h-14 bg-white rounded-full flex items-center justify-center text-[#C5A059] shadow-sm shrink-0 group-hover:scale-110 transition-transform">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <div>
                <div class="text-[#5C6656] text-xs font-bold uppercase tracking-widest mb-1">E-mail</div>
                <div class="text-xl font-bold text-[#1B4332]">pajula@volny.cz</div>
              </div>
            </a>
          </div>

          <div class="lg:col-span-7">
            <div class="bg-white p-8 md:p-12 rounded-sm border border-[#1B4332]/10 shadow-xl shadow-[#1B4332]/5">
              <h3 class="text-2xl font-bold text-[#1B4332] uppercase mb-8 border-b border-[#EFEBE0] pb-4">Předběžná objednávka</h3>

              <form name="rezervace" method="POST" data-netlify="true" class="space-y-6">
                <input type="hidden" name="form-name" value="rezervace" />

                <div class="grid sm:grid-cols-2 gap-6">
                  <div>
                    <label for="jmeno" class="block text-xs font-bold text-[#5C6656] uppercase tracking-wider mb-2">Jméno *</label>
                    <input type="text" id="jmeno" name="jmeno" required class="w-full bg-[#F8F7F2] border border-[#1B4332]/10 rounded-sm px-4 py-3 text-[#1B4332] focus:outline-none focus:border-[#C5A059] focus:ring-1 focus:ring-[#C5A059] transition-colors" />
                  </div>
                  <div>
                    <label for="prijmeni" class="block text-xs font-bold text-[#5C6656] uppercase tracking-wider mb-2">Příjmení *</label>
                    <input type="text" id="prijmeni" name="prijmeni" required class="w-full bg-[#F8F7F2] border border-[#1B4332]/10 rounded-sm px-4 py-3 text-[#1B4332] focus:outline-none focus:border-[#C5A059] focus:ring-1 focus:ring-[#C5A059] transition-colors" />
                  </div>
                </div>

                <div class="grid sm:grid-cols-2 gap-6">
                  <div>
                    <label for="email" class="block text-xs font-bold text-[#5C6656] uppercase tracking-wider mb-2">Váš e-mail *</label>
                    <input type="email" id="email" name="email" required class="w-full bg-[#F8F7F2] border border-[#1B4332]/10 rounded-sm px-4 py-3 text-[#1B4332] focus:outline-none focus:border-[#C5A059] focus:ring-1 focus:ring-[#C5A059] transition-colors" />
                  </div>
                  <div>
                    <label for="telefon" class="block text-xs font-bold text-[#5C6656] uppercase tracking-wider mb-2">Telefon</label>
                    <input type="tel" id="telefon" name="telefon" class="w-full bg-[#F8F7F2] border border-[#1B4332]/10 rounded-sm px-4 py-3 text-[#1B4332] focus:outline-none focus:border-[#C5A059] focus:ring-1 focus:ring-[#C5A059] transition-colors" />
                  </div>
                </div>

                <div>
                  <label for="adresa" class="block text-xs font-bold text-[#5C6656] uppercase tracking-wider mb-2">Adresa</label>
                  <input type="text" id="adresa" name="adresa" class="w-full bg-[#F8F7F2] border border-[#1B4332]/10 rounded-sm px-4 py-3 text-[#1B4332] focus:outline-none focus:border-[#C5A059] focus:ring-1 focus:ring-[#C5A059] transition-colors" />
                </div>

                <div class="grid sm:grid-cols-2 gap-6 pt-4 border-t border-[#EFEBE0]">
                  <div>
                    <label for="prijezd" class="block text-xs font-bold text-[#5C6656] uppercase tracking-wider mb-2">Příjezd *</label>
                    <input type="date" id="prijezd" name="prijezd" required class="w-full bg-[#F8F7F2] border border-[#1B4332]/10 rounded-sm px-4 py-3 text-[#5C6656] focus:outline-none focus:border-[#C5A059] focus:ring-1 focus:ring-[#C5A059] transition-colors" />
                  </div>
                  <div>
                    <label for="odjezd" class="block text-xs font-bold text-[#5C6656] uppercase tracking-wider mb-2">Odjezd *</label>
                    <input type="date" id="odjezd" name="odjezd" required class="w-full bg-[#F8F7F2] border border-[#1B4332]/10 rounded-sm px-4 py-3 text-[#5C6656] focus:outline-none focus:border-[#C5A059] focus:ring-1 focus:ring-[#C5A059] transition-colors" />
                  </div>
                </div>

                <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 pt-4 border-t border-[#EFEBE0]">
                  <div>
                    <label for="dospeli" class="block text-[10px] font-bold text-[#5C6656] uppercase tracking-wider mb-2">Dospělí</label>
                    <input type="number" min="0" id="dospeli" name="dospeli" class="w-full bg-[#F8F7F2] border border-[#1B4332]/10 rounded-sm px-4 py-2 text-center text-[#1B4332] focus:outline-none focus:border-[#C5A059]" />
                  </div>
                  <div>
                    <label for="deti" class="block text-[10px] font-bold text-[#5C6656] uppercase tracking-wider mb-2">Děti</label>
                    <input type="number" min="0" id="deti" name="deti" class="w-full bg-[#F8F7F2] border border-[#1B4332]/10 rounded-sm px-4 py-2 text-center text-[#1B4332] focus:outline-none focus:border-[#C5A059]" />
                  </div>
                  <div>
                    <label for="apartmany" class="block text-[10px] font-bold text-[#5C6656] uppercase tracking-wider mb-2">Apartm.</label>
                    <input type="number" min="0" id="apartmany" name="apartmany" class="w-full bg-[#F8F7F2] border border-[#1B4332]/10 rounded-sm px-4 py-2 text-center text-[#1B4332] focus:outline-none focus:border-[#C5A059]" />
                  </div>
                  <div>
                    <label for="chaty" class="block text-[10px] font-bold text-[#5C6656] uppercase tracking-wider mb-2">Chaty</label>
                    <input type="number" min="0" id="chaty" name="chaty" class="w-full bg-[#F8F7F2] border border-[#1B4332]/10 rounded-sm px-4 py-2 text-center text-[#1B4332] focus:outline-none focus:border-[#C5A059]" />
                  </div>
                </div>

                <div class="pt-4 border-t border-[#EFEBE0]">
                  <label for="poznamka" class="block text-xs font-bold text-[#5C6656] uppercase tracking-wider mb-2">Poznámka</label>
                  <textarea id="poznamka" name="poznamka" rows="4" class="w-full bg-[#F8F7F2] border border-[#1B4332]/10 rounded-sm px-4 py-3 text-[#1B4332] focus:outline-none focus:border-[#C5A059] focus:ring-1 focus:ring-[#C5A059] transition-colors"></textarea>
                </div>

                <div class="pt-4 flex flex-col sm:flex-row items-center justify-between gap-6">
                  <p class="text-xs text-[#5C6656] font-light">Pole označená hvězdičkou (*) jsou povinná.</p>
                  <button type="submit" class="w-full sm:w-auto px-8 py-4 bg-[#C5A059] text-white text-sm font-bold uppercase tracking-widest rounded-sm hover:bg-[#b08d4b] transition-all shadow-lg shadow-[#C5A059]/20 cursor-pointer"> Odeslat objednávku </button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-[#F8F7F2] border-t border-[#1B4332]/5">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
          <div>
            <span class="inline-flex items-center gap-2 text-[#C5A059] text-[11px] font-bold tracking-[0.3em] uppercase mb-4">
              <span class="w-8 h-[1px] bg-[#C5A059]/50"></span>
              Kde nás najdete
            </span>
            <h2 class="text-3xl md:text-4xl font-bold text-[#1B4332] uppercase mb-6">
              Rekreační areál <br />
              <span class="text-[#C5A059]">Malá Hrdlička</span>
            </h2>
            <p class="text-[#5C6656] font-light mb-10 max-w-md leading-relaxed">Areál se nachází v krásném a klidném prostředí v těsné blízkosti Slapské přehrady. Ideální místo pro Váš odpočinek v přírodě i aktivní zábavu.</p>

            <div class="space-y-8">
              <div class="flex items-start gap-5">
                <div class="mt-1 w-12 h-12 bg-white rounded-full flex items-center justify-center text-[#4F7942] shrink-0 shadow-sm border border-[#1B4332]/10">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                </div>
                <div>
                  <div class="text-[#5C6656] text-[10px] font-bold uppercase tracking-widest mb-1.5">Kontaktní adresa</div>
                  <div class="text-[#1B4332] font-medium leading-relaxed">
                    <span class="font-bold">Pavla Špačková</span><br />
                    Osada Hrdlička<br />
                    obec Čím, okres Příbram
                  </div>
                </div>
              </div>

              <div class="flex items-start gap-5">
                <div class="mt-1 w-12 h-12 bg-white rounded-full flex items-center justify-center text-[#4F7942] shrink-0 shadow-sm border border-[#1B4332]/10">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
                </div>
                <div>
                  <div class="text-[#5C6656] text-[10px] font-bold uppercase tracking-widest mb-1.5">GPS Souřadnice</div>
                  <div class="text-[#1B4332] font-medium">49°47'2.453"N, 14°24'10.093"E</div>
                </div>
              </div>
            </div>
          </div>

          <div class="relative w-full h-[400px] lg:h-[500px] rounded-sm overflow-hidden shadow-lg border border-[#1B4332]/10 group bg-white">
            <iframe src="https://maps.google.com/maps?q=Rekrea%C4%8Dn%C3%AD%20are%C3%A1l%20Mal%C3%A1%20Hrdli%C4%8Dka,%20%C4%8C%C3%ADm&t=&z=14&ie=UTF8&iwloc=&output=embed" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" class="grayscale opacity-90 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700"></iframe>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
