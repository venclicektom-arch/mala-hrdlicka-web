    /* DĚTI (Žlutá) */
    .card-deti.is-visible { border-color: rgba(249, 199, 79, 0.4); transform: translateY(-0.5rem); }
    .card-deti.is-visible .icon-wrap { background-color: #F9C74F; }
    .card-deti.is-visible .icon-svg { color: #143024; }
    .card-deti.is-visible h3 { color: #F9C74F; }

    /* OHEŇ (Oranžová) */
    .card-ohen.is-visible { border-color: rgba(243, 114, 44, 0.4); transform: translateY(-0.5rem); }
    .card-ohen.is-visible .icon-wrap { background-color: #F3722C; }
    .card-ohen.is-visible .icon-svg { color: #143024; }
    .card-ohen.is-visible h3 { color: #F3722C; }

    /* SPORT (Zelená) */
    .card-sport.is-visible { border-color: rgba(144, 190, 109, 0.4); transform: translateY(-0.5rem); }
    .card-sport.is-visible .icon-wrap { background-color: #90BE6D; }
    .card-sport.is-visible .icon-svg { color: #143024; }
    .card-sport.is-visible h3 { color: #90BE6D; }
  }
</style>

<script>
  // Script, který sleduje skrolování a přiřazuje třídu 'is-visible'
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        // Pokud je karta uprostřed obrazovky (isIntersecting), přidáme jí třídu
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        } else {
          entry.target.classList.remove('is-visible');
        }
      });
    }, {
      // Spustí se, když se karta dostane do středních 40% obrazovky (nahoře a dole je 30% mrtvá zóna)
      rootMargin: '-30% 0px -30% 0px',
      threshold: 0
    });

    // Sledujeme všechny karty s třídou .scroll-card
    document.querySelectorAll('.scroll-card').forEach(card => {
      observer.observe(card);
    });
  });
</script>

