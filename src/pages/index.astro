<style>
  /* Tyto styly se aktivují jen na mobilech/tabletech a simulují hover efekt při skrolování */
  @media (max-width: 1024px) {
    /* VODA (Modrá) */
    .card-voda.is-visible { border-color: rgba(76, 201, 240, 0.4); transform: translateY(-0.5rem); }
    .card-voda.is-visible .icon-wrap { background-color: #4CC9F0; }
