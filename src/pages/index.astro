      }
    }
  </style>

  <script>
    // Script, který sleduje skrolování a přiřazuje třídu 'is-visible'
    document.addEventListener('DOMContentLoaded', () => {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            // Pokud je karta uprostřed obrazovky (isIntersecting), přidáme jí třídu
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
            } else {
              entry.target.classList.remove('is-visible');
            }
          });
        },
        {
          // Spustí se, když se karta dostane do středních 40% obrazovky (nahoře a dole je 30% mrtvá zóna)
          rootMargin: '-30% 0px -30% 0px',
          threshold: 0,
        },
      );

      // Sledujeme všechny karty s třídou .scroll-card
      document.querySelectorAll('.scroll-card').forEach((card) => {
        observer.observe(card);
      });
    });
  </script>

