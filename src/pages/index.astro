---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import fotoArealu from '../assets/images/homepage/areal-mala-hrdlicka-slapy.jpeg';
import fotoApartmanHlavni from '../assets/images/homepage/ubytovani-apartman-hlavni.jpeg';
import fotoChatkaHlavni from '../assets/images/homepage/ubytovani-chatka-hlavni.jpeg';
import fotoBazen from '../assets/images/galerie/bazen-areal-slapy.jpeg';
import fotoHriste from '../assets/images/galerie/detske-hriste-prolezacky.jpeg';
import fotoVoda from '../assets/images/galerie/voda-slapy-paddleboardy.jpeg';
import fotoPosezeni from '../assets/images/galerie/venkovni-posezeni-relax.jpeg';
import fotoOhniste from '../assets/images/galerie/ohniste-opekani-spekacku.jpeg';
import fotoApartmanDetail from '../assets/images/galerie/ubytovani-apartman-detail.jpeg';
---

<Layout title="Apartmány a chatky Malá Hrdlička | Ubytování Slapy" description="Hledáte klidnou dovolenou na Slapech? Navštivte areál Malá Hrdlička. Apartmány a chatky v lese, jen 5 minut chůze od přehrady.">
  <section class="relative w-full h-[85vh] min-h-[600px] flex items-center justify-center overflow-hidden bg-[#F4EBD0]">
    <img src="/img/hero.jpg" alt="Letní dovolená na Slapech" class="absolute inset-0 w-full h-full object-cover object-center" />

    <div class="absolute inset-0 bg-[#C5A059]/5 mix-blend-multiply"></div>

    <div class="absolute inset-0 bg-gradient-to-t from-[#0F3D3E]/60 via-[#1B4332]/10 to-transparent"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center -mt-12 md:-mt-16">
      <div class="inline-flex items-center gap-3 mb-5 bg-[#C5A059]/10 backdrop-blur-sm px-4 py-1.5 rounded-full border border-[#C5A059]/20 shadow-inner">
        <span class="w-1.5 h-1.5 rounded-full bg-[#C5A059]"></span>
        <span class="text-[#FFF8E7] text-[10px] uppercase tracking-[0.2em] font-semibold drop-shadow-sm"> Slapská přehrada, osada Hrdlička </span>
      </div>

      <h1 class="text-3xl md:text-5xl lg:text-6xl text-[#FFF8E7] font-medium leading-[1.15] tracking-tight mb-5 drop-shadow-xl">
        Vaše letní pohoda <br class="hidden md:block" /> na břehu Slapské přehrady
      </h1>

      <p class="text-base md:text-lg text-[#F4F1EA]/95 font-light max-w-2xl mx-auto mb-8 drop-shadow-md">Slunce, voda a vůně borovic. Rodinné apartmány a chatky jako stvořené pro dokonalou letní dovolenou.</p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#nabidka" class="bg-[#C5A059] text-white px-10 py-4 rounded-sm text-[13px] uppercase tracking-[0.2em] font-bold hover:bg-white hover:text-[#4F7942] hover:-translate-y-0.5 transition-all duration-300 shadow-2xl shadow-[#C5A059]/20"> Prohlédnout ubytování </a>
      </div>
    </div>
  </section>
  <div class="bg-[#4F7942] border-t border-white/10 relative z-20 shadow-xl">
    <div class="max-w-7xl mx-auto px-6 py-6 md:py-10 flex flex-col md:flex-row justify-between divide-y divide-white/10 md:divide-y-0 md:divide-x md:divide-white/10">
      <div class="flex items-center justify-start md:justify-center gap-4 group w-full md:w-1/3 py-4 md:py-0">
        <div class="w-10 h-10 md:w-14 md:h-14 rounded-full bg-white/5 flex items-center justify-center border border-white/10 group-hover:border-[#C5A059]/50 group-hover:bg-[#C5A059]/10 transition-all duration-300 shrink-0">
          <svg class="w-5 h-5 md:w-7 md:h-7 text-[#C5A059]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.364 6.364l-.707-.707M6.364 17.636l.707-.707M17.636 6.364l.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"></path></svg>
        </div>
        <div class="text-left">
          <p class="text-[10px] md:text-[11px] uppercase tracking-[0.2em] font-bold text-[#C5A059]/80 mb-0.5 md:mb-1">Provoz areálu</p>
          <p class="text-base md:text-xl font-bold text-white tracking-wide">Červen – Říjen</p>
        </div>
      </div>

      <div class="flex items-center justify-start md:justify-center gap-4 group w-full md:w-1/3 py-4 md:py-0">
        <div class="w-10 h-10 md:w-14 md:h-14 rounded-full bg-white/5 flex items-center justify-center border border-white/10 group-hover:border-[#C5A059]/50 group-hover:bg-[#C5A059]/10 transition-all duration-300 shrink-0">
          <svg class="w-5 h-5 md:w-7 md:h-7 text-[#C5A059]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
        </div>
        <div class="text-left">
          <p class="text-[10px] md:text-[11px] uppercase tracking-[0.2em] font-bold text-[#C5A059]/80 mb-0.5 md:mb-1">Celková kapacita</p>
          <p class="text-base md:text-xl font-bold text-white tracking-wide">48 lůžek</p>
        </div>
      </div>

      <div class="flex items-center justify-start md:justify-center gap-4 group w-full md:w-1/3 py-4 md:py-0">
        <div class="w-10 h-10 md:w-14 md:h-14 rounded-full bg-white/5 flex items-center justify-center border border-white/10 group-hover:border-[#C5A059]/50 group-hover:bg-[#C5A059]/10 transition-all duration-300 shrink-0">
          <svg class="w-5 h-5 md:w-7 md:h-7 text-[#C5A059]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
        </div>
        <div class="text-left">
          <p class="text-[10px] md:text-[11px] uppercase tracking-[0.2em] font-bold text-[#C5A059]/80 mb-0.5 md:mb-1">Lokalita</p>
          <p class="text-base md:text-xl font-bold text-white tracking-wide">Osada Hrdlička</p>
        </div>
      </div>
    </div>
  </div>

  <section class="py-16 md:py-24 bg-[#EFEBE0] overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="relative z-10">
          <span class="inline-flex items-center gap-2 text-[11px] font-bold tracking-[0.2em] uppercase text-[#C5A059] mb-6"> Pár slov o nás </span>
          <h2 class="text-3xl md:text-5xl font-semibold text-[#1B4332] tracking-tight mb-6 leading-[1.2]">
            Rodinný areál s <br />
            <span class="text-[#C5A059]">tradicí a klidem.</span>
          </h2>

          <div class="text-[#3A4535] font-light leading-relaxed text-[15px] mb-8">
            <p>Areál se nachází na levém břehu Slapské přehrady v osadě Hrdlička. Je obklopen lesem a k vodě dojdete příjemnou procházkou za 5 minut. Naším cílem je poskytnout rodinám s dětmi bezpečné místo pro klidný odpočinek i aktivní zábavu u venkovního bazénu.</p>
          </div>

          <div class="grid sm:grid-cols-2 gap-x-6 gap-y-5 mb-10 pt-6 border-t border-[#DEDACF]">
            <div class="flex items-start gap-3">
              <div class="mt-1 text-[#C5A059]">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              </div>
              <div>
                <span class="block text-sm font-semibold text-[#1B4332]">Snadná dostupnost</span>
                <span class="text-xs text-[#5C6656] font-light leading-snug">Příjezd autem až na místo, parkování zajištěno přímo v areálu.</span>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="mt-1 text-[#C5A059]">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              </div>
              <div>
                <span class="block text-sm font-semibold text-[#1B4332]">Stravování v okolí</span>
                <span class="text-xs text-[#5C6656] font-light leading-snug">Restaurace v přímém sousedství, prodejna potravin vzdálena 2 km.</span>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="mt-1 text-[#C5A059]">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              </div>
              <div>
                <span class="block text-sm font-semibold text-[#1B4332]">Domácí mazlíčci</span>
                <span class="text-xs text-[#5C6656] font-light leading-snug">Psi malých plemen jsou vítáni (areál není uzpůsoben k volnému pobíhání).</span>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="mt-1 text-[#C5A059]">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              </div>
              <div>
                <span class="block text-sm font-semibold text-[#1B4332]">Letní provoz</span>
                <span class="text-xs text-[#5C6656] font-light leading-snug">Otevřeno od června do října s celkovou kapacitou 48 lůžek.</span>
              </div>
            </div>
          </div>

          <div class="mt-2">
            <a href="/o-nas" class="inline-flex items-center gap-3 text-[12px] uppercase tracking-widest font-bold text-[#1B4332] group bg-white px-6 py-3 border border-[#DEDACF] rounded-sm hover:border-[#C5A059] transition-colors shadow-sm">
              <span class="group-hover:text-[#C5A059] transition-colors">Zjistit více o našem areálu</span>
              <svg class="w-4 h-4 text-[#C5A059] group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -top-10 -right-10 w-64 h-64 bg-[#E4DFC9] rounded-full -z-10 shadow-sm"></div>

          <div class="aspect-[4/5] rounded-sm overflow-hidden border border-[#DEDACF] bg-[#EAE5D9] flex items-center justify-center relative group shadow-xl shadow-[#1B4332]/10">
            <div class="relative w-full h-full overflow-hidden bg-[#DEDACF] border border-[#1B4332]/5">
              <Image src={fotoArealu} alt="Letecký pohled na rekreační areál Malá Hrdlička u Slapské přehrady s bazénem" width={630} height={840} widths={[400, 630]} sizes="(max-width: 768px) 400px, 630px" quality={50} format="avif" loading="lazy" class="w-full h-full object-cover [backface-visibility:hidden] [transform:translateZ(0)]" />

              <div class="absolute bottom-4 left-4 bg-black/40 backdrop-blur-md px-3 py-1 rounded-sm pointer-events-none">
                <p class="text-white text-[10px] uppercase tracking-widest font-bold">Areál Malá Hrdlička</p>
              </div>
            </div>

            <div class="absolute bottom-6 left-6 bg-[#4F7942] p-4 border border-[#C5A059]/30 hidden md:block shadow-lg">
              <p class="text-[10px] uppercase tracking-[0.2em] font-bold text-[#C5A059] mb-1">Kapacita</p>
              <p class="text-sm font-medium text-white">Komfort pro 48 hostů</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white relative" id="nabidka">
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="text-center max-w-2xl mx-auto mb-20">
        <span class="inline-flex items-center gap-2 text-[11px] font-bold tracking-[0.2em] uppercase text-[#C5A059] mb-4">
          <span class="w-4 h-[1px] bg-[#C5A059]"></span>
          Naše nabídka
          <span class="w-4 h-[1px] bg-[#C5A059]"></span>
        </span>
        <h2 class="text-3xl md:text-5xl font-semibold text-[#1B4332] tracking-tight mb-6">Vyberte si svůj styl odpočinku</h2>
        <p class="text-[#4A5446] font-light leading-relaxed text-lg">Ať už preferujete pohodlí pevných zdí, nebo večery na dřevěné terase, máme pro vás to správné zázemí uprostřed zeleně.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-10 lg:gap-16">
        <div class="group flex flex-col bg-white rounded-sm border border-[#E8E6E1] overflow-hidden transition-all duration-300 hover:shadow-2xl hover:shadow-[#1B4332]/15 hover:-translate-y-1">
          <div class="relative h-72 w-full bg-[#EFEBE0] flex items-center justify-center overflow-hidden">
            <div class="w-full h-full bg-[#DEDACF] border border-[#1B4332]/5 relative overflow-hidden">
              <Image src={fotoApartmanHlavni} alt="Hlavní zděná budova s komfortními apartmány a terasami" width={672} height={504} widths={[400, 672]} sizes="(max-width: 768px) 400px, 672px" quality={50} format="avif" loading="lazy" class="w-full h-full object-cover [backface-visibility:hidden] [transform:translateZ(0)]" />

              <div class="absolute bottom-3 left-3 bg-white/90 px-3 py-1 text-[9px] sm:text-[10px] uppercase font-bold tracking-widest text-[#4F7942] z-10 pointer-events-none">Hlavní budova</div>
            </div>
          </div>
          <div class="p-8 md:p-10 flex flex-col flex-grow">
            <h3 class="text-2xl md:text-3xl font-semibold text-[#1B4332] mb-4">Apartmány</h3>
            <p class="text-[#4A5446] text-[15px] leading-relaxed mb-8 flex-grow font-light">Maximální komfort pro ty, kteří vyžadují vyšší standard. Vlastní zázemí, moderní vybavení a klid pro nerušenou rodinnou dovolenou.</p>
            <ul class="space-y-4 mb-10 text-[14px] text-[#2C3329]">
              <li class="flex items-center gap-4">
                <span class="w-1.5 h-1.5 bg-[#C5A059] rounded-full"></span> Vlastní sociální zařízení
              </li>
              <li class="flex items-center gap-4">
                <span class="w-1.5 h-1.5 bg-[#C5A059] rounded-full"></span> Plně vybavená kuchyně
              </li>
              <li class="flex items-center gap-4">
                <span class="w-1.5 h-1.5 bg-[#C5A059] rounded-full"></span> Oddělené ložnice pro soukromí
              </li>
            </ul>
            <div class="pt-6 border-t border-[#E8E6E1] flex items-center justify-between">
              <div>
                <span class="block text-[10px] uppercase tracking-widest text-[#8A9386] font-bold mb-1">Cena od</span>
                <span class="text-xl font-semibold text-[#1B4332]">Cena na dotaz</span>
              </div>
              <a href="/ubytovani#apartmany" class="inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.1em] font-bold text-[#C5A059] hover:text-[#1B4332] transition-colors">
                Detail
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </a>
            </div>
          </div>
        </div>

        <div class="group flex flex-col bg-white rounded-sm border border-[#E8E6E1] overflow-hidden transition-all duration-300 hover:shadow-2xl hover:shadow-[#1B4332]/15 hover:-translate-y-1">
          <div class="relative h-72 w-full bg-[#EFEBE0] flex items-center justify-center overflow-hidden">
            <div class="relative h-72 w-full bg-[#EFEBE0] flex items-center justify-center overflow-hidden">
              <Image src={fotoChatkaHlavni} alt="Dřevěná chatka s prostornou terasou v areálu Malá Hrdlička" width={672} height={504} widths={[400, 672]} sizes="(max-width: 768px) 400px, 672px" quality={50} format="avif" loading="lazy" class="w-full h-full object-cover [backface-visibility:hidden] [transform:translateZ(0)]" />

              <div class="absolute bottom-3 left-3 bg-white/90 px-3 py-1 text-[9px] uppercase font-bold tracking-widest text-[#4F7942] z-10 pointer-events-none">Chatka a terasa</div>
            </div>
          </div>
          <div class="p-8 md:p-10 flex flex-col flex-grow">
            <h3 class="text-2xl md:text-3xl font-semibold text-[#1B4332] mb-4">Chatky</h3>
            <p class="text-[#4A5446] text-[15px] leading-relaxed mb-8 flex-grow font-light">Klasická letní romantika. Ranní káva na dřevěné terase, vůně lesa a bezprostřední kontakt s přírodou.</p>
            <ul class="space-y-4 mb-10 text-[14px] text-[#2C3329]">
              <li class="flex items-center gap-4">
                <span class="w-1.5 h-1.5 bg-[#C5A059] rounded-full"></span> Zastřešená terasa k posezení
              </li>
              <li class="flex items-center gap-4">
                <span class="w-1.5 h-1.5 bg-[#C5A059] rounded-full"></span> Vlastní menší kuchyňka
              </li>
              <li class="flex items-center gap-4">
                <span class="w-1.5 h-1.5 bg-[#C5A059] rounded-full"></span> Společné sociální zařízení (blízko)
              </li>
            </ul>
            <div class="pt-6 border-t border-[#E8E6E1] flex items-center justify-between">
              <div>
                <span class="block text-[10px] uppercase tracking-widest text-[#8A9386] font-bold mb-1">Cena od</span>
                <span class="text-xl font-semibold text-[#1B4332]">Cena na dotaz</span>
              </div>
              <a href="/ubytovani#chatky" class="inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.1em] font-bold text-[#C5A059] hover:text-[#1B4332] transition-colors">
                Detail
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-[#4F7942] relative" id="zazitky">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto mb-20">
        <span class="inline-flex items-center gap-2 text-[11px] font-bold tracking-[0.2em] uppercase text-[#C5A059] mb-4">
          <span class="w-4 h-[1px] bg-[#C5A059]"></span>
          Vybavení areálu
          <span class="w-4 h-[1px] bg-[#C5A059]"></span>
        </span>
        <h2 class="text-3xl md:text-5xl font-semibold text-white tracking-tight mb-6 leading-[1.2]">Víc než jen ubytování</h2>
        <p class="text-[#EFEBE0]/90 font-light leading-relaxed text-lg">Náš areál je stvořený pro rodinnou pohodu. Vše, co potřebujete k dokonalé letní dovolené, máte přímo na dosah ruky.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        <div class="group scroll-card card-voda p-8 rounded-sm bg-white/10 backdrop-blur-sm border border-white/10 hover:-translate-y-2 transition-all duration-300 hover:bg-white/15 hover:border-[#4CC9F0]/40">
          <div class="icon-wrap w-16 h-16 rounded-full bg-[#C5A059]/15 flex items-center justify-center mb-6 group-hover:bg-[#4CC9F0] transition-colors duration-300 shadow-inner">
            <svg class="icon-svg w-7 h-7 text-[#C5A059] group-hover:text-[#4F7942] transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 21c3 0 7-1.5 10-1.5s7 1.5 10 1.5M3 15c3 0 7-1.5 10-1.5s7 1.5 10 1.5M4 11h16M8 11V5a2 2 0 012-2h4a2 2 0 012 2v6"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3 group-hover:text-[#4CC9F0] transition-colors">Voda a relaxace</h3>
          <p class="text-[#EFEBE0]/80 text-sm leading-relaxed font-light">Přístup k vodě máte jen pár minut chůze. K dispozici jsou lodičky pro hosty a travnaté plochy pro váš odpočinek.</p>
        </div>

        <div class="group scroll-card card-deti p-8 rounded-sm bg-white/10 backdrop-blur-sm border border-white/10 hover:-translate-y-2 transition-all duration-300 hover:bg-white/15 hover:border-[#F9C74F]/40">
          <div class="icon-wrap w-16 h-16 rounded-full bg-[#C5A059]/15 flex items-center justify-center mb-6 group-hover:bg-[#F9C74F] transition-colors duration-300 shadow-inner">
            <svg class="icon-svg w-7 h-7 text-[#C5A059] group-hover:text-[#4F7942] transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3 group-hover:text-[#F9C74F] transition-colors">Ráj pro děti</h3>
          <p class="text-[#EFEBE0]/80 text-sm leading-relaxed font-light">Bezpečný, udržovaný areál s dětským hřištěm, pískovištěm a spoustou prostoru pro bezstarostné běhání.</p>
        </div>

        <div class="group scroll-card card-ohen p-8 rounded-sm bg-white/10 backdrop-blur-sm border border-white/10 hover:-translate-y-2 transition-all duration-300 hover:bg-white/15 hover:border-[#F3722C]/40">
