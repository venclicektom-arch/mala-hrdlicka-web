      /* OHEŇ (Oranžová) */
      .card-ohen.is-visible {
        border-color: rgba(243, 114, 44, 0.4);
        transform: translateY(-0.5rem);
      }
      .card-ohen.is-visible .icon-wrap {
        background-color: #f3722c;
      }
      .card-ohen.is-visible .icon-svg {
        color: #143024;
      }
      .card-ohen.is-visible h3 {
        color: #f3722c;
      }

      /* SPORT (Zelená) */
      .card-sport.is-visible {
        border-color: rgba(144, 190, 109, 0.4);
        transform: translateY(-0.5rem);
      }
      .card-sport.is-visible .icon-wrap {
