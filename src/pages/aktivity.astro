---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';

// Importy obrázků pro další sekce si sem pak budeme postupně přidávat
// import fotoParnik from '../assets/images/aktuality/parnik.jpg';

const pageTitle = 'Aktivity a výlety | Areál Malá Hrdlička';
const pageDescription = 'Zábava pro celou rodinu u Slapské přehrady. Zjistěte, co dělat přímo v areálu, půjčte si lodičku, nebo vyrazte na výlet do okolí.';
---

<Layout title={pageTitle} description={pageDescription}>
  <main>
    <section class="relative pt-16 pb-12 lg:pt-24 lg:pb-16 bg-[#4F7942] overflow-hidden">
      <div class="absolute -top-24 -right-24 w-96 h-96 bg-[#C5A059]/30 rounded-full blur-[100px] pointer-events-none"></div>
      <div class="absolute inset-0 opacity-[0.05]" style="background-image: url('https://www.transparenttextures.com/patterns/natural-paper.png');"></div>

      <div class="max-w-7xl mx-auto px-6 relative z-10 text-center">
        <span class="text-[#EFEBE0] text-[10px] md:text-[11px] font-bold tracking-[0.4em] uppercase mb-4 block opacity-80"> Volný čas na Slapech </span>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white tracking-tight leading-tight mb-6">
          Aktivní dovolená <br class="hidden sm:block" />
          <span class="text-[#C5A059]">plná zážitků</span>
        </h1>

        <p class="text-[#EFEBE0]/90 text-base md:text-lg font-light max-w-xl mx-auto leading-relaxed">Od klidného rybaření v zátoce, přes dětské radovánky u bazénu, až po adrenalin v nedalekém lanovém parku. Vyberte si svůj vlastní rytmus.</p>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-white relative">
      <div class="max-w-7xl mx-auto px-6">
        <div class="mb-16">
          <div class="inline-block px-3 py-1 rounded-sm bg-[#4F7942]/10 text-[#4F7942] text-[11px] font-bold tracking-widest uppercase mb-4">Zábava u nás</div>
          <h2 class="text-3xl md:text-4xl font-bold text-[#1B4332] leading-tight">
            Vše pro aktivní odpočinek <br />
            <span class="text-[#C5A059]">na jednom místě</span>
          </h2>
        </div>

        <div class="grid lg:grid-cols-12 gap-12 items-start">
          <div class="lg:col-span-7 grid sm:grid-cols-2 gap-6 md:gap-8">
            <div class="group">
              <div class="w-12 h-12 bg-[#EFEBE0] rounded-sm flex items-center justify-center mb-5 group-hover:bg-[#4F7942] transition-colors duration-300">
                <svg class="w-6 h-6 text-[#4F7942] group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
              <h3 class="text-lg font-bold text-[#1B4332] mb-3 uppercase tracking-wide">Míčové hry</h3>
              <p class="text-[#5C6656] font-light leading-relaxed text-[15px]">
                K dispozici je antukový <strong>tenisový kurt</strong>, hřiště na <strong>volejbal i nohejbal</strong>. Ideální pro ranní zápas nebo odpolední turnaj s přáteli.
              </p>
            </div>

            <div class="group">
              <div class="w-12 h-12 bg-[#EFEBE0] rounded-sm flex items-center justify-center mb-5 group-hover:bg-[#4F7942] transition-colors duration-300">
                <svg class="w-6 h-6 text-[#4F7942] group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
              <h3 class="text-lg font-bold text-[#1B4332] mb-3 uppercase tracking-wide">Pro naše nejmenší</h3>
              <p class="text-[#5C6656] font-light leading-relaxed text-[15px]">
                Bezpečné <strong>trampolíny</strong> a dostatek prostoru pro běhání. Areál je uzavřený, takže si děti mohou hrát, zatímco vy v klidu odpočíváte.
              </p>
            </div>

            <div class="group">
              <div class="w-12 h-12 bg-[#EFEBE0] rounded-sm flex items-center justify-center mb-5 group-hover:bg-[#4F7942] transition-colors duration-300">
                <svg class="w-6 h-6 text-[#4F7942] group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 12l3-3 3 3 4-4M8 21h8a2 2 0 002-2v-9a2 2 0 00-2-2H8a2 2 0 00-2 2v9a2 2 0 002 2z"></path></svg>
              </div>
              <h3 class="text-lg font-bold text-[#1B4332] mb-3 uppercase tracking-wide">Stolní tenis</h3>
              <p class="text-[#5C6656] font-light leading-relaxed text-[15px]">Klasická letní zábava, která neomrzí. Ping-pongový stůl je připraven pro rekreační hráče i zapálené přeborníky.</p>
            </div>

            <div class="group">
              <div class="w-12 h-12 bg-[#EFEBE0] rounded-sm flex items-center justify-center mb-5 group-hover:bg-[#4F7942] transition-colors duration-300">
                <svg class="w-6 h-6 text-[#4F7942] group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.642.316a4 4 0 01-1.845.443H8a2 2 0 01-2-2V7a2 2 0 012-2h.674a2 2 0 011.845.443l.642.316a6 6 0 003.86.517l2.387-.477a2 2 0 001.022-.547V15.428z"></path></svg>
              </div>
              <h3 class="text-lg font-bold text-[#1B4332] mb-3 uppercase tracking-wide">Rybářský ráj</h3>
              <p class="text-[#5C6656] font-light leading-relaxed text-[15px]">Díky poloze u lesa a kousek od vody jsme ideální základnou pro rybáře všech věkových kategorií hledající klidnou zátoku.</p>
            </div>
          </div>

          <div class="lg:col-span-5 relative">
            <div class="relative w-full max-w-sm mx-auto lg:max-w-none">
              <div class="aspect-[4/3] bg-[#F8F7F2] border-2 border-dashed border-[#4F7942]/20 rounded-sm shadow-xl rotate-2 hover:rotate-0 transition-transform duration-500 flex flex-col items-center justify-center text-[#4F7942]/50 relative z-10">
                <svg class="w-12 h-12 mb-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                <span class="font-bold uppercase tracking-widest text-xs">Místo pro fotku</span>
                <span class="text-[10px] mt-1 opacity-70">Poměr 4:3 (např. 800x600px)</span>
              </div>
              <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-[#C5A059]/10 rounded-full z-0 pointer-events-none"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-32 bg-[#EFEBE0] relative border-t border-[#1B4332]/5">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">
          <div class="lg:col-span-6 flex flex-col items-center lg:items-start relative order-2 lg:order-1 mt-8 lg:mt-0">
            <div class="w-full max-w-sm lg:w-[400px] relative z-0">
              <div class="absolute -top-6 -left-6 w-24 h-24 bg-[#4F7942]/10 rounded-full -z-10"></div>

              <div class="aspect-square bg-white border border-[#1B4332]/5 p-2 shadow-lg rotate-[-2deg] flex flex-col items-center justify-center text-[#4F7942]/40 relative z-10">
                <svg class="w-10 h-10 mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                <span class="font-bold uppercase tracking-widest text-[10px]">Menší fotka (1:1)</span>
              </div>
            </div>

            <div class="w-[95%] max-w-sm lg:w-[320px] bg-[#1B4332] text-white p-6 md:p-8 rounded-sm shadow-xl z-20 border-t-4 border-[#C5A059] -mt-12 lg:absolute lg:-bottom-12 lg:-right-6">
              <div class="flex items-center gap-4 mb-3">
                <div class="w-10 h-10 bg-[#C5A059] rounded-full flex items-center justify-center text-white flex-shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <h4 class="font-bold text-lg uppercase tracking-wide">Lodička zdarma</h4>
              </div>
              <p class="text-white/80 font-light text-[14px] leading-relaxed">
                Abychom vám cestu za zážitky co nejvíce zpříjemnili, rádi vám <strong>zdarma zapůjčíme</strong> naši lodičku.
              </p>
            </div>
          </div>

          <div class="lg:col-span-6 order-1 lg:order-2">
            <span class="inline-block px-3 py-1 rounded-sm bg-[#C5A059]/10 text-[#C5A059] text-[11px] font-bold tracking-widest uppercase mb-4">Zážitky na vodě</span>
            <h2 class="text-3xl md:text-4xl font-bold text-[#1B4332] leading-tight mb-8">
              Vyplujte přímo z <br />
              <span class="text-[#C5A059]">naší pláže</span>
            </h2>

            <div class="space-y-8">
              <div>
                <h3 class="text-xl font-bold text-[#1B4332] mb-3 flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-[#1B4332]/5 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-[#C5A059]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  </div>
                  Plavba parníkem
                </h3>
                <p class="text-[#5C6656] font-light leading-relaxed text-[15px] lg:pl-11">Velkým zážitkem pro celou rodinu je plavba parníkem po Slapské přehrady. Zastávka se nachází přímo u pláže v osadě Hrdlička, odkud se můžete vydat směrem na hráz přehrady nebo na Živohošť.</p>
              </div>

              <div>
                <h3 class="text-xl font-bold text-[#1B4332] mb-3 flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-[#1B4332]/5 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-[#4F7942]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 10a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1v-4z"></path></svg>
                  </div>
                  Aquapark Měřín
                </h3>
                <p class="text-[#5C6656] font-light leading-relaxed text-[15px] lg:pl-11">Oblíbeným cílem je také Aquapark Měřín na protějším břehu, vzdálený přibližně 1 km. Dostanete se k němu nejen autem, ale i stylově – na lodičce nebo parníkem.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-white relative">
      <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <div class="order-2 lg:order-1">
            <div class="mb-12">
              <span class="inline-block px-3 py-1 rounded-sm bg-[#4F7942]/10 text-[#4F7942] text-[11px] font-bold tracking-widest uppercase mb-4">Kousek od nás</span>
              <h2 class="text-3xl md:text-4xl font-bold text-[#1B4332] leading-tight">
                Hledáte trochu <br />
                <span class="text-[#C5A059]">adrenalinu?</span>
              </h2>
            </div>

            <div class="relative mt-8 lg:mt-0 pt-2">
              <div class="absolute left-5 top-4 bottom-4 w-[2px] bg-[#EFEBE0] -z-10"></div>

              <div class="space-y-12 py-2">
                <div class="relative pl-16">
                  <div class="absolute left-0 top-0 w-10 h-10 bg-white border-2 border-[#4F7942] rounded-full flex items-center justify-center shadow-sm">
                    <div class="w-3 h-3 bg-[#4F7942] rounded-full"></div>
                  </div>
                  <div class="pt-1">
                    <h3 class="text-xl font-bold text-[#1B4332] mb-3 uppercase tracking-wide">Lanový park Slapy</h3>
                    <p class="text-[#5C6656] font-light leading-relaxed text-[15px]">Největší lanový park ve Středních Čechách, zasazený do stínu vysokých smrků na břehu přehrady. Nabízí trasy různé obtížnosti i dětské lanové bludiště pro ty nejmenší.</p>
                  </div>
                </div>

                <div class="relative pl-16">
                  <div class="absolute left-0 top-0 w-10 h-10 bg-white border-2 border-[#C5A059] rounded-full flex items-center justify-center shadow-sm">
                    <div class="w-3 h-3 bg-[#C5A059] rounded-full"></div>
                  </div>
                  <div class="pt-1">
                    <div class="inline-block px-2 py-0.5 rounded-sm bg-[#1B4332]/5 text-[#1B4332] text-[10px] font-bold tracking-widest uppercase mb-2">Vzdálenost: cca 3 km</div>
                    <h3 class="text-xl font-bold text-[#1B4332] mb-3 uppercase tracking-wide">TEPfactor Chotilsko</h3>
                    <p class="text-[#5C6656] font-light leading-relaxed text-[15px]">Dobrodružný areál inspirovaný legendární pevností Boyard. Čeká vás překonávání překážek, luštění šifer a spousta zábavy, kde prověříte svou fyzičku i logiku.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="order-1 lg:order-2 flex flex-col items-center h-full relative">
            <div class="relative w-full max-w-[320px] mx-auto lg:mr-0 lg:ml-auto mt-auto mb-10 lg:mb-0">
              <div class="absolute -top-6 -right-6 w-24 h-24 bg-[#C5A059]/10 rounded-full blur-xl -z-10 pointer-events-none"></div>

              <div class="aspect-[4/5] bg-white border border-[#1B4332]/5 p-2 shadow-xl rotate-[3deg] rounded-sm relative z-10 flex flex-col items-center justify-center text-[#4F7942]/40">
                <svg class="w-8 h-8 mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                <span class="font-bold uppercase tracking-widest text-[10px] text-center px-2">Fotka adrenalinu<br />(Poměr 4:5)</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-[#1B4332] relative overflow-hidden border-t-4 border-[#C5A059]">
      <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="text-center max-w-2xl mx-auto mb-12">
          <svg class="w-10 h-10 text-[#C5A059] mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
          <h2 class="text-3xl md:text-4xl font-bold text-white leading-tight mb-4">
            Kam vyrazit na <span class="text-[#C5A059]">výlet?</span>
          </h2>
          <p class="text-white/80 font-light text-[17px]">Okolí nabízí pestrou síť turistických i cyklistických tras a úžasné historické památky. Vyberte si podle chuti.</p>
        </div>

        <div class="flex flex-wrap justify-center gap-3 md:gap-4 max-w-4xl mx-auto mb-16">
          <span class="px-5 py-2.5 bg-white/10 text-white rounded-full text-sm font-medium border border-white/20 hover:bg-[#C5A059] hover:border-[#C5A059] transition-colors duration-300 cursor-default">Zámek Březnice</span>
          <span class="px-5 py-2.5 bg-white/10 text-white rounded-full text-sm font-medium border border-white/20 hover:bg-[#C5A059] hover:border-[#C5A059] transition-colors duration-300 cursor-default">Zámek Konopiště</span>
          <span class="px-5 py-2.5 bg-white/10 text-white rounded-full text-sm font-medium border border-white/20 hover:bg-[#C5A059] hover:border-[#C5A059] transition-colors duration-300 cursor-default">Zámek Dobříš</span>
          <span class="px-5 py-2.5 bg-white/10 text-white rounded-full text-sm font-medium border border-white/20 hover:bg-[#C5A059] hover:border-[#C5A059] transition-colors duration-300 cursor-default">Rožmitál pod Třemšínem</span>
          <span class="px-5 py-2.5 bg-white/10 text-white rounded-full text-sm font-medium border border-white/20 hover:bg-[#C5A059] hover:border-[#C5A059] transition-colors duration-300 cursor-default">Nový Knín</span>
          <span class="px-5 py-2.5 bg-white/10 text-white rounded-full text-sm font-medium border border-white/20 hover:bg-[#C5A059] hover:border-[#C5A059] transition-colors duration-300 cursor-default">Hrad Karlštejn</span>
          <span class="px-5 py-2.5 bg-white/10 text-white rounded-full text-sm font-medium border border-white/20 hover:bg-[#C5A059] hover:border-[#C5A059] transition-colors duration-300 cursor-default">Zbraslav</span>
          <span class="px-5 py-2.5 bg-white/10 text-white rounded-full text-sm font-medium border border-white/20 hover:bg-[#C5A059] hover:border-[#C5A059] transition-colors duration-300 cursor-default">Příbram (Svatá Hora)</span>
          <span class="px-5 py-2.5 bg-white/10 text-white rounded-full text-sm font-medium border border-white/20 hover:bg-[#C5A059] hover:border-[#C5A059] transition-colors duration-300 cursor-default">Jelení park Homole</span>
        </div>

        <div class="max-w-2xl mx-auto bg-white/5 border border-white/10 rounded-sm p-6 md:p-8 text-center shadow-lg">
          <p class="text-[#EFEBE0] font-light text-[15px] leading-relaxed">
            <strong class="text-white font-semibold block mb-2">Nevíte, kam dřív?</strong>
            Podrobnější informace o aktivitách a výletech najdete také na naší <span class="text-[#C5A059] font-medium">informační tabuli přímo v areálu</span>. Rádi vám osobně poradíme, co stojí za to vidět.
          </p>
        </div>
      </div>
    </section>
  </main>
</Layout>
