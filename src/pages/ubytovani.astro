---
import Layout from '../layouts/Layout.astro';

// Definice metadat pro tuto konkrétní stránku
const pageTitle = 'Ubytování | Areál Malá Hrdlička';
const pageDescription = 'Vyberte si ubytování v našem areálu na Slapech. Nabízíme útulné chatky i komfortní apartmány v bezprostřední blízkosti přehrady, ideální pro rodiny s dětmi.';
---

<Layout title={pageTitle} description={pageDescription}>
  <main>
    <section id="apartmany" class="py-16 md:py-24 bg-[#EFEBE0] scroll-mt-20 overflow-hidden">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-stretch mb-16">
          <div class="lg:col-span-6 relative pb-12 lg:pb-0 h-full flex items-center">
            <div class="absolute top-4 left-4 w-full h-[95%] border-2 border-[#C5A059]/20 rounded-sm -z-10 hidden lg:block"></div>
            <div class="absolute -bottom-10 -left-10 w-72 h-72 bg-[#C5A059]/10 rounded-full -z-0 blur-3xl"></div>

            <div class="w-full relative z-20 flex flex-col gap-8 sm:gap-12">
              <div class="w-full aspect-[4/3] md:aspect-[3/2] bg-white p-3 sm:p-4 shadow-2xl transform -rotate-1 hover:rotate-0 transition-transform duration-500 mx-auto">
                <div class="w-full h-full bg-[#DEDACF] flex flex-col items-center justify-center border border-[#1B4332]/5 relative overflow-hidden group cursor-pointer">
                  <svg class="w-12 h-12 sm:w-16 sm:h-16 text-[#C1BCB3] group-hover:scale-110 transition-transform duration-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                  <div class="absolute bottom-3 left-3 bg-white/90 px-3 py-1 text-[9px] sm:text-[10px] uppercase font-bold tracking-widest text-[#4F7942]">Hlavní budova</div>
                </div>
              </div>

              <div class="grid grid-cols-2 gap-6 sm:gap-8 w-full mx-auto">
                <div class="aspect-[4/3] sm:aspect-square bg-white p-3 sm:p-4 shadow-xl transform rotate-2 hover:rotate-0 transition-transform duration-500">
                  <div class="w-full h-full bg-[#C1BCB3] flex items-center justify-center border border-[#1B4332]/5 relative overflow-hidden group">
                    <svg class="w-8 h-8 sm:w-10 sm:h-10 text-white/50 group-hover:scale-110 transition-transform duration-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                    <div class="absolute bottom-2 right-2 bg-[#1B4332]/80 px-2 py-1 text-[8px] uppercase font-bold tracking-widest text-white">Terasa</div>
                  </div>
                </div>

                <div class="aspect-[4/3] sm:aspect-square bg-white p-3 sm:p-4 shadow-lg transform -rotate-1 hover:rotate-0 transition-transform duration-500">
                  <div class="w-full h-full bg-[#DEDACF] flex items-center justify-center border border-[#1B4332]/5 relative overflow-hidden group">
                    <svg class="w-8 h-8 sm:w-10 sm:h-10 text-[#C1BCB3] group-hover:scale-110 transition-transform duration-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    <div class="absolute bottom-2 left-2 bg-white/90 px-2 py-1 text-[8px] uppercase font-bold tracking-widest text-[#C5A059]">Interiér</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="lg:col-span-6 flex flex-col justify-center">
            <h2 class="text-3xl md:text-5xl font-bold text-[#1B4332] mb-6 leading-tight">
              Komfortní apartmány <br />
              <span class="text-[#C5A059]">s vlastní terasou</span>
            </h2>

            <div class="space-y-4 text-[#3A4535] font-light leading-relaxed text-[17px] mb-10">
              <p>
                Objevte příjemné ubytování v dvoupodlažním zděném rekreačním objektu s terasovitým uspořádáním, který nabízí celkem deset komfortních apartmánů. Každý apartmán má <strong>vlastní vstup přímo na terasu</strong>, což zajišťuje maximální soukromí i pohodlí během vašeho pobytu.
              </p>
              <p>
                Apartmány jsou ideální pro čtyři osoby a zároveň nabízejí možnost až dvou přistýlek formou rozkládací sedačky v obývacím pokoji – skvělé řešení pro rodiny i menší skupiny přátel. Vybrané apartmány (č. 4 a 6–12) navíc nabízejí <strong>oddělenou ložnici</strong>, která zajišťuje ještě větší pohodlí a soukromí.
              </p>
              <p>
                Každý apartmán disponuje vlastním sociálním zařízením (WC a sprcha) a je plně vybaven pro váš komfort: nechybí čtyři lůžka s možností přistýlek, televizor, jídelní kout, dostatek úložných prostor ani kompletně vybavená <strong>kuchyňská linka s lednicí a mrazákem</strong>, elektrickým vařičem a varnou konvicí.
              </p>
            </div>

            <div class="bg-white p-6 sm:p-8 rounded-sm shadow-sm border-l-4 border-[#C5A059]">
              <h3 class="text-xs font-bold uppercase tracking-widest text-[#1B4332] mb-6">Shrnutí vybavení</h3>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-8 gap-x-6">
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 bg-[#4F7942]/10 rounded-full flex shrink-0 items-center justify-center text-[#4F7942]">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                  </div>
                  <div>
                    <p class="text-[10px] uppercase font-bold text-[#C5A059] tracking-wider mb-1">Až pro 6 osob</p>
                    <p class="text-[#1B4332] font-bold text-sm mb-1">4 lůžka + 2 přistýlky</p>
                    <p class="text-[#5C6656] text-xs leading-snug">Přistýlky formou rozkládací sedačky v obývacím pokoji.</p>
                  </div>
                </div>

                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 bg-[#4F7942]/10 rounded-full flex shrink-0 items-center justify-center text-[#4F7942]">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                  </div>
                  <div>
                    <p class="text-[10px] uppercase font-bold text-[#C5A059] tracking-wider mb-1">Soukromí a relax</p>
                    <p class="text-[#1B4332] font-bold text-sm mb-1">Vlastní vstup na terasu</p>
                    <p class="text-[#5C6656] text-xs leading-snug">Uvnitř navíc najdete televizor a pohodlný jídelní kout.</p>
                  </div>
                </div>

                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 bg-[#4F7942]/10 rounded-full flex shrink-0 items-center justify-center text-[#4F7942]">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
                  </div>
                  <div>
                    <p class="text-[10px] uppercase font-bold text-[#C5A059] tracking-wider mb-1">Sociální zařízení</p>
                    <p class="text-[#1B4332] font-bold text-sm mb-1">Vlastní WC a sprcha</p>
                    <p class="text-[#5C6656] text-xs leading-snug">Plné soukromí a dostatek úložných prostor pro vaše věci.</p>
                  </div>
                </div>

                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 bg-[#4F7942]/10 rounded-full flex shrink-0 items-center justify-center text-[#4F7942]">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                  </div>
                  <div>
                    <p class="text-[10px] uppercase font-bold text-[#C5A059] tracking-wider mb-1">Vaření</p>
                    <p class="text-[#1B4332] font-bold text-sm mb-1">Vybavená kuchyňská linka</p>
                    <p class="text-[#5C6656] text-xs leading-snug">Lednice s mrazákem, el. vařič a varná konvice.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="relative w-full">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-sm font-bold uppercase tracking-[0.2em] text-[#1B4332]">Prohlédněte si interiér</h3>

            <a href="/galerie" class="hidden sm:inline-flex items-center gap-2 text-[11px] font-bold text-[#C5A059] uppercase tracking-widest hover:text-[#1B4332] transition-colors">
              Všechny fotky
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
          </div>

          <button id="apt-prev" class="hidden lg:flex absolute left-[-24px] top-[60%] -translate-y-1/2 z-10 w-12 h-12 bg-white rounded-full shadow-lg border border-black/5 items-center justify-center text-[#1B4332] hover:bg-[#C5A059] hover:text-white transition-all">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
          </button>

          <div id="apt-slider" class="flex gap-4 sm:gap-6 overflow-x-auto snap-x snap-mandatory pb-8 -mx-6 px-6 lg:mx-0 lg:px-0 scrollbar-hide scroll-smooth">
            <div class="snap-start shrink-0 w-[85vw] sm:w-[45vw] lg:w-[350px] xl:w-[400px] aspect-[4/3] bg-white p-2 shadow-md">
              <div class="w-full h-full bg-[#DEDACF] flex items-center justify-center text-xs font-bold text-[#1B4332]/40 uppercase tracking-widest border border-[#1B4332]/5">Interiér 1</div>
            </div>
            <div class="snap-start shrink-0 w-[85vw] sm:w-[45vw] lg:w-[350px] xl:w-[400px] aspect-[4/3] bg-white p-2 shadow-md">
              <div class="w-full h-full bg-[#DEDACF] flex items-center justify-center text-xs font-bold text-[#1B4332]/40 uppercase tracking-widest border border-[#1B4332]/5">Kuchyňka</div>
            </div>
            <div class="snap-start shrink-0 w-[85vw] sm:w-[45vw] lg:w-[350px] xl:w-[400px] aspect-[4/3] bg-white p-2 shadow-md">
              <div class="w-full h-full bg-[#DEDACF] flex items-center justify-center text-xs font-bold text-[#1B4332]/40 uppercase tracking-widest border border-[#1B4332]/5">Ložnice</div>
            </div>
            <div class="snap-start shrink-0 w-[85vw] sm:w-[45vw] lg:w-[350px] xl:w-[400px] aspect-[4/3] bg-white p-2 shadow-md">
              <div class="w-full h-full bg-[#DEDACF] flex items-center justify-center text-xs font-bold text-[#1B4332]/40 uppercase tracking-widest border border-[#1B4332]/5">Terasa</div>
            </div>
            <div class="snap-start shrink-0 w-[85vw] sm:w-[45vw] lg:w-[350px] xl:w-[400px] aspect-[4/3] bg-white p-2 shadow-md">
              <div class="w-full h-full bg-[#DEDACF] flex items-center justify-center text-xs font-bold text-[#1B4332]/40 uppercase tracking-widest border border-[#1B4332]/5">Koupelna</div>
            </div>
          </div>

          <button id="apt-next" class="hidden lg:flex absolute right-[-24px] top-[60%] -translate-y-1/2 z-10 w-12 h-12 bg-white rounded-full shadow-lg border border-black/5 items-center justify-center text-[#1B4332] hover:bg-[#C5A059] hover:text-white transition-all">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </button>

          <div class="mt-2 text-center sm:hidden">
            <a href="/galerie" class="inline-flex items-center gap-2 text-[11px] font-bold text-[#C5A059] uppercase tracking-widest">
              Zobrazit všechny fotky
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slider = document.getElementById('apt-slider');
    const prevBtn = document.getElementById('apt-prev');
    const nextBtn = document.getElementById('apt-next');

    if (slider && prevBtn && nextBtn) {
      // Při kliknutí odscrolujeme o šířku jednoho obrázku (cca 400px + mezera)
      prevBtn.addEventListener('click', () => {
        slider.scrollBy({ left: -420, behavior: 'smooth' });
      });
      nextBtn.addEventListener('click', () => {
        slider.scrollBy({ left: 420, behavior: 'smooth' });
      });
    }
  });
</script>
