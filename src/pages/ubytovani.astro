    const aptNext = document.getElementById('apt-next');
    if (aptSlider && aptPrev && aptNext) {
      aptPrev.addEventListener('click', () => aptSlider.scrollBy({ left: -420, behavior: 'smooth' }));
      aptNext.addEventListener('click', () => aptSlider.scrollBy({ left: 420, behavior: 'smooth' }));
    }

    // Chatky slider
    const chatSlider = document.getElementById('chat-slider');
    const chatPrev = document.getElementById('chat-prev');
    const chatNext = document.getElementById('chat-next');
