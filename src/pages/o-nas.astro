---
export const prerender = true;

import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import fotoPriroda from '../assets/images/o-nas/priroda-slapy.jpeg';

// Tady definuješ to, co Layout očekává
const pageTitle = 'O nás | Areál Malá Hrdlička';
const pageDescription = 'Poznejte příběh areálu Malá Hrdlička. Nabízíme bezpečné a klidné zázemí pro rodiny s dětmi v bezprostřední blízkosti Slapské přehrady.';
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="relative pt-16 pb-12 lg:pt-24 lg:pb-16 bg-[#4F7942] overflow-hidden">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-[#C5A059]/30 rounded-full blur-[100px] pointer-events-none"></div>
    <div class="absolute inset-0 opacity-[0.08] pointer-events-none" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.4) 1px, transparent 0); background-size: 24px 24px;" aria-hidden="true"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10 text-center">
      <span class="text-[#EFEBE0] text-[10px] md:text-[11px] font-bold tracking-[0.4em] uppercase mb-4 block opacity-80"> Osada Hrdlička — Slapy </span>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white tracking-tight leading-tight mb-6">
        Příběh naší <span class="text-[#C5A059]">Malé Hrdličky</span>
      </h1>

      <p class="text-[#EFEBE0]/90 text-base md:text-lg font-light max-w-xl mx-auto leading-relaxed">Místo v srdci přírody, kde se zastavil čas, aby rodiny mohly prožít nezapomenutelné léto.</p>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-[#EFEBE0]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7">
          <h2 class="text-3xl md:text-4xl font-semibold text-[#1B4332] tracking-tight mb-8 leading-tight">
            Klidná osada, kde <br />
            <span class="text-[#C5A059]">příroda hraje prim.</span>
          </h2>

          <div class="space-y-6 text-[#3A4535] font-light leading-relaxed text-[17px] md:text-[19px]">
            <p>
              Areál „Malá Hrdlička“ se nachází v těsné blízkosti Slapské přehrady, na jejím levém břehu mezi Ždání a Živohoští, v osadě Hrdlička (obec Čím). Celý areál je obklopen vzrostlým lesem a k vodě dojdete příjemnou procházkou za pouhých <strong>5 minut</strong>.
            </p>
            <p>Naším cílem je nabídnout zázemí, kde si děti užijí spoustu bezpečné zábavy a rodiče si zároveň odpočinou. Jsme ideálním místem pro ty, kteří hledají klidné a přátelské prostředí, kde mají přírodu doslova za dveřmi.</p>
            <p class="italic text-[#4F7942] font-medium border-l-2 border-[#C5A059] pl-6">"Okolí poskytuje široké možnosti vyžití – od nenáročných procházek a cyklovýletů až po vodní radovánky u přehrady."</p>
          </div>
        </div>

        <div class="lg:col-span-5 relative">
          <div class="relative w-full max-w-sm mx-auto lg:max-w-none">
            <div class="aspect-[4/5] bg-white p-3 rounded-sm shadow-2xl border border-white/50 rotate-2 hover:rotate-0 transition-transform duration-500 overflow-hidden relative z-0">
              <div class="w-full h-full bg-[#DEDACF] overflow-hidden">
                <Image src={fotoPriroda} alt="Příroda v okolí Slapské přehrady" width={800} height={1000} quality={70} format="avif" loading="lazy" class="w-full h-full object-cover" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-6">
          <div class="inline-block px-3 py-1 rounded-sm bg-[#4F7942]/10 text-[#4F7942] text-[11px] font-bold tracking-widest uppercase mb-6">Aktivní odpočinek</div>
          <h2 class="text-3xl md:text-4xl font-bold text-[#1B4332] mb-8 leading-tight">
            Slapská přehrada <br />
            <span class="text-[#C5A059]">na dosah ruky</span>
          </h2>
          <div class="prose prose-lg text-[#3A4535] font-light leading-relaxed">
            <p class="mb-6">Rozlehlá vodní plocha Slapské přehrady vybízí ke koupání, projížďkám na lodičkách, surfingu či jachtingu a je také oblíbeným místem rybářů.</p>
            <p>
              Pokud preferujete sport na souši, přímo v osadě můžete za poplatek využít kvalitní <span class="font-medium text-[#1B4332]">antukový tenisový kurt</span>, který skvěle doplňuje naše vlastní sportoviště v areálu.
            </p>
          </div>
        </div>

        <div class="lg:col-span-6 lg:pl-12">
          <div class="bg-[#F8F7F2] p-8 md:p-10 rounded-sm shadow-xl shadow-[#1B4332]/5 border-l-4 border-[#C5A059] relative overflow-hidden">
            <div class="absolute top-0 right-0 w-24 h-24 bg-[#C5A059]/5 rounded-bl-full"></div>

            <h3 class="text-xl font-bold text-[#1B4332] mb-8 uppercase tracking-wider">Shrnutí informací</h3>

            <ul class="space-y-8">
              <li class="flex items-center gap-5">
                <div class="flex-shrink-0 w-10 h-10 bg-white rounded-full flex items-center justify-center shadow-sm">
                  <svg class="w-5 h-5 text-[#4F7942]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                </div>
                <div>
                  <p class="text-xs text-[#5C6656] uppercase font-bold tracking-tighter">Kapacita areálu</p>
                  <p class="text-[#1B4332] font-semibold text-lg">48 lůžek v chatkách a apartmánech</p>
                </div>
              </li>

              <li class="flex items-center gap-5">
                <div class="flex-shrink-0 w-10 h-10 bg-white rounded-full flex items-center justify-center shadow-sm">
                  <svg class="w-5 h-5 text-[#4F7942]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                </div>
                <div>
                  <p class="text-xs text-[#5C6656] uppercase font-bold tracking-tighter">Provozní doba</p>
                  <p class="text-[#1B4332] font-semibold text-lg">Od června do října</p>
                </div>
              </li>

              <li class="flex items-center gap-5">
                <div class="flex-shrink-0 w-10 h-10 bg-white rounded-full flex items-center justify-center shadow-sm">
                  <svg class="w-5 h-5 text-[#4F7942]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <div>
                  <p class="text-xs text-[#5C6656] uppercase font-bold tracking-tighter">Domácí mazlíčci</p>
                  <p class="text-[#1B4332] font-semibold text-lg">Pobyt psů malých plemen povolen</p>
                  <p class="text-xs text-[#3A4535] opacity-70 italic mt-1">(V areálu pouze na vodítku)</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-[#EFEBE0] border-t border-[#C5A059]/20">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="inline-flex items-center gap-2 text-[12px] font-bold tracking-[0.3em] uppercase text-[#4F7942] mb-4">
          <span class="w-8 h-[1px] bg-[#4F7942]"></span>
          Vybavení areálu
          <span class="w-8 h-[1px] bg-[#4F7942]"></span>
        </span>
        <h2 class="text-3xl md:text-4xl font-bold text-[#1B4332] mb-6 leading-tight">
          Vše pro vaši <span class="text-[#C5A059]">perfektní dovolenou</span>
        </h2>
        <p class="text-[#3A4535] text-lg font-light">Od ranní kávy u vody, přes odpolední sportovní turnaje, až po večerní opékání buřtů u táboráku. Mysleli jsme na všechno.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        <div class="bg-white p-8 rounded-md shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group border border-black/5">
          <div class="w-14 h-14 bg-[#4F7942]/10 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#4F7942] transition-colors duration-300">
            <svg class="w-7 h-7 text-[#4F7942] group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-[#1B4332] mb-3">Dětský ráj</h3>
          <p class="text-[#5C6656] font-light text-[15px] leading-relaxed">Venkovní bazén, velké trampolíny, pískoviště, houpačky a spousta bezpečného prostoru pro dětské hry.</p>
        </div>

        <div class="bg-white p-8 rounded-md shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group border border-black/5">
          <div class="w-14 h-14 bg-[#C5A059]/10 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#C5A059] transition-colors duration-300">
            <svg class="w-7 h-7 text-[#C5A059] group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-[#1B4332] mb-3">Aktivní pohyb</h3>
          <p class="text-[#5C6656] font-light text-[15px] leading-relaxed">Přímo v areálu máme hřiště na nohejbal a volejbal, stolní tenis a i antukový tenisový kurt.</p>
        </div>

        <div class="bg-white p-8 rounded-md shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group border border-black/5">
          <div class="w-14 h-14 bg-[#1B4332]/10 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#1B4332] transition-colors duration-300">
            <svg class="w-7 h-7 text-[#1B4332] group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-[#1B4332] mb-3">Zážitky na vodě</h3>
          <p class="text-[#5C6656] font-light text-[15px] leading-relaxed">K dispozici pro vás máme naše vlastní veslice a molo. Ideální pro ranní rybaření nebo romantickou projížďku.</p>
        </div>

        <div class="bg-white p-8 rounded-md shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group border border-black/5">
          <div class="w-14 h-14 bg-[#C5A059]/10 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#C5A059] transition-colors duration-300">
            <svg class="w-7 h-7 text-[#C5A059] group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.99 7.99 0 0120 13a7.99 7.99 0 01-2.343 5.657z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.879 16.121A3 3 0 1012.015 11L11 14l-2.121 2.121z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-[#1B4332] mb-3">Společné večery</h3>
          <p class="text-[#5C6656] font-light text-[15px] leading-relaxed">Sdílejte zážitky u velkého ohniště se sezením. Pro případ horšího počasí je tu pro všechny naše klubovna.</p>
        </div>

        <div class="bg-white p-8 rounded-md shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group border border-black/5">
          <div class="w-14 h-14 bg-[#4F7942]/10 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#4F7942] transition-colors duration-300">
            <svg class="w-7 h-7 text-[#4F7942] group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-[#1B4332] mb-3">Pohodlný příjezd</h3>
          <p class="text-[#5C6656] font-light text-[15px] leading-relaxed">Snadná dostupnost pro osobní vozidla s možností parkování přímo a bezpečně v našem uzavřeném areálu.</p>
        </div>

        <div class="bg-white p-8 rounded-md shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group border border-black/5">
          <div class="w-14 h-14 bg-[#1B4332]/10 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#1B4332] transition-colors duration-300">
            <svg class="w-7 h-7 text-[#1B4332] group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-[#1B4332] mb-3">Vše na dosah</h3>
          <p class="text-[#5C6656] font-light text-[15px] leading-relaxed">V bezprostřední blízkosti areálu najdete skvělou restauraci a prodejna potravin s celotýdenním provozem je jen 2 km daleko.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-32 bg-[#1B4332] relative overflow-hidden">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[#2D5A27] rounded-full blur-[120px] opacity-40 -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-[#C5A059] rounded-full blur-[100px] opacity-20 translate-y-1/3 -translate-x-1/4 pointer-events-none"></div>

    <div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
      <span class="inline-flex items-center gap-3 text-[12px] font-bold tracking-[0.3em] uppercase text-[#C5A059] mb-6">
        <span class="w-10 h-[1px] bg-[#C5A059]/50"></span>
        Léto čeká
        <span class="w-10 h-[1px] bg-[#C5A059]/50"></span>
      </span>

      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
        Přijeďte si k nám <br class="hidden md:block" />
        <span class="text-[#C5A059] italic font-serif font-normal">odpočinout</span>
      </h2>

      <p class="text-[#EFEBE0]/80 text-lg md:text-xl font-light mb-10 max-w-2xl mx-auto">Kapacita je omezena na 48 lůžek, abychom zaručili klid pro všechny naše hosty. Prohlédněte si naše chatky a apartmány.</p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 md:gap-6">
        <a href="/ubytovani" class="w-full sm:w-auto px-8 py-4 bg-[#C5A059] text-white text-sm font-bold uppercase tracking-widest hover:bg-[#b08d4b] transition-colors duration-300 rounded-sm shadow-lg shadow-[#C5A059]/20"> Prohlédnout ubytování </a>
        <a href="/cenik" class="w-full sm:w-auto px-8 py-4 bg-transparent text-white text-sm font-bold uppercase tracking-widest border border-white/30 hover:border-white hover:bg-white/5 transition-all duration-300 rounded-sm"> Ceník a rezervace </a>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-[0] z-20 translate-y-[1px]">
      <svg class="block w-full h-[40px] md:h-[80px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0,0 C300,120 900,120 1200,0 L1200,120 L0,120 Z" fill="#4F7942"></path>
      </svg>
    </div>
  </section>
</Layout>
