---
import Layout from '../layouts/Layout.astro';

// Tady definuješ to, co Layout očekává
const pageTitle = "O nás | Areál s rodinnou tradicí na Slapech";
const pageDescription = "Poznejte příběh areálu Malá Hrdlička. Nabízíme bezpečné a klidné zázemí pro rodiny s dětmi v bezprostřední blízkosti Slapské přehrady.";
---

<Layout title={pageTitle} description={pageDescription}>
  <main>
    
<section class="relative pt-16 pb-12 lg:pt-24 lg:pb-16 bg-[#4F7942] overflow-hidden">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-[#C5A059]/30 rounded-full blur-[100px] pointer-events-none"></div>
    <div class="absolute inset-0 opacity-[0.05]" style="background-image: url('https://www.transparenttextures.com/patterns/natural-paper.png');"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10 text-center">
        <span class="text-[#EFEBE0] text-[10px] md:text-[11px] font-bold tracking-[0.4em] uppercase mb-4 block opacity-80">
        Osada Hrdlička — Slapy
        </span>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white tracking-tight leading-tight mb-6">
        Příběh naší <span class="text-[#C5A059]">Malé Hrdličky</span>
        </h1>

        <p class="text-[#EFEBE0]/90 text-base md:text-lg font-light max-w-xl mx-auto leading-relaxed">
        Místo v srdci přírody, kde se zastavil čas, aby rodiny mohly prožít nezapomenutelné léto.
        </p>
    </div>
</section>

    <section class="py-16 md:py-24 bg-[#EFEBE0]">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid lg:grid-cols-12 gap-12 items-center">
            
            <div class="lg:col-span-7">
                <h2 class="text-3xl md:text-4xl font-semibold text-[#1B4332] tracking-tight mb-8 leading-tight">
                Klidná osada, kde <br /> 
                <span class="text-[#C5A059]">příroda hraje prim.</span>
                </h2>
                
                <div class="space-y-6 text-[#3A4535] font-light leading-relaxed text-[17px] md:text-[19px]">
                <p>
                    Areál „Malá Hrdlička“ se nachází v těsné blízkosti Slapské přehrady, na jejím levém břehu mezi Ždání a Živohoští, v osadě Hrdlička (obec Čím). Celý areál je obklopen vzrostlým lesem a k vodě dojdete příjemnou procházkou za pouhých <strong>5 minut</strong>.
                </p>
                <p>
                    Naším cílem je nabídnout zázemí, kde si děti užijí spoustu bezpečné zábavy a rodiče si zároveň odpočinou. Jsme ideálním místem pro ty, kteří hledají klidné a přátelské prostředí, kde mají přírodu doslova za dveřmi.
                </p>
                <p class="italic text-[#4F7942] font-medium border-l-2 border-[#C5A059] pl-6">
                    "Okolí poskytuje široké možnosti vyžití – od nenáročných procházek a cyklovýletů až po vodní radovánky u přehrady."
                </p>
                </div>
            </div>

            <div class="lg:col-span-5">
                <div class="relative">
                <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-[#C5A059]/10 rounded-full -z-10"></div>
                
                <div class="aspect-[4/5] bg-white p-3 rounded-sm shadow-2xl border border-white/50 rotate-2 hover:rotate-0 transition-transform duration-500">
                    <div class="w-full h-full bg-[#DEDACF] flex items-center justify-center overflow-hidden">
                    <svg class="w-16 h-16 text-[#C1BCB3]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    </div>
                </div>
                </div>
            </div>

            </div>
        </div>
    </section>

  </main>
</Layout>